generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id           String      @id @default(cuid())
  name         String
  slug         String      @unique
  logoUrl      String
  category     String
  topProducts  Json
  email        String?
  createdAt    DateTime    @default(now())
  isBoosted    Boolean     @default(false)
  boostedUntil DateTime?

  kits         GraphicKit[]
  incentives   Incentive[]
}

model GraphicKit {
  id            String        @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  productName   String
  productImage  String
  promotionText String
  deepLink      String?
  shortHash     String?       @unique
  imageUrls     Json?
  status        String        @default("pending")
  jobId         String?
  createdAt     DateTime      @default(now())

  verification  Verification?
  incentive     Incentive?
}

model Verification {
  id            String     @id @default(cuid())
  kitId         String     @unique
  kit           GraphicKit @relation(fields: [kitId], references: [id])
  screenshotUrl String
  confidence    Float
  status        String     @default("pending")
  reviewedAt    DateTime?
  notes         String?
}

model Incentive {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  kitId        String     @unique
  kit          GraphicKit @relation(fields: [kitId], references: [id])
  type         String
  activatedAt  DateTime   @default(now())
  expiresAt    DateTime
}
