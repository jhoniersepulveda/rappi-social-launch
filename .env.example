# ── Base de datos (Neon PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=<openssl rand -base64 32>
NEXTAUTH_URL=https://tu-app.web.app

# ── IA — Gemini (imagen principal) ────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── IA — Replicate / Ideogram (fallback técnico) ──────────────────────────────
REPLICATE_API_KEY=r8_...

# ── IA — Anthropic Claude (verificación de publicación) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Almacenamiento S3 / Cloudflare R2 (opcional en dev, requerido en prod) ────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=rappi-social-launch
S3_REGION=us-east-1
STORAGE_ENDPOINT=

# ── Redis / Upstash (cola de trabajos BullMQ) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....

# ── Acceso KAM ────────────────────────────────────────────────────────────────
KAM_PASSWORD=rappi_kam_2024
